NODE_ENV=development

# Web applications
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_ADMIN_URL=http://localhost:3001
NEXT_PUBLIC_API_URL=http://localhost:4000

# API
API_PORT=4000
JWT_SECRET=replace-with-at-least-32-random-characters
DOMAIN_KEY_ENCRYPTION_SECRET=replace-with-at-least-32-random-characters
WEBMAIL_CREDENTIAL_ENCRYPTION_SECRET=replace-with-at-least-32-random-characters
IMAP_HOST=jposta-mailserver
IMAP_PORT=993
IMAP_SECURE=true
IMAP_TLS_SERVERNAME=mail.jposta.com
MAIL_HOSTNAME=mail.jposta.com
SPF_INCLUDE_HOST=_spf.jposta.com
MAIL_SERVER_IP=
WEBMAIL_IMAP_TIMEOUT_MS=12000
# Set to false only for internal testing with self-signed certificates.
WEBMAIL_IMAP_REJECT_UNAUTHORIZED=true
# Optional real IMAP integration test credentials; never set these in committed files.
JPOSTA_TEST_IMAP_EMAIL=
JPOSTA_TEST_IMAP_PASSWORD=
WEB_ORIGIN=http://localhost:3000
API_URL=http://localhost:4000
MAIL_PROVISIONER_URL=http://host.docker.internal:4100
MAIL_PROVISIONER_TOKEN=replace-with-private-provisioner-token

# Supabase Auth, configured when authentication is introduced.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Infrastructure
# Docker/container default. For host-local Prisma CLI, use postgresql://jposta:jposta@localhost:5432/jposta.
DATABASE_URL=postgresql://jposta:jposta@postgres:5432/jposta
REDIS_URL=redis://:jposta-redis-password@redis:6379

# PostgreSQL
POSTGRES_USER=jposta
POSTGRES_PASSWORD=jposta
POSTGRES_DB=jposta

# Redis
REDIS_PASSWORD=jposta-redis-password
