generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                      String         @id @default(cuid())
  email                   String         @unique
  username                String         @unique
  primaryEmail            String         @unique
  recoveryEmail           String?
  recoveryEmailVerifiedAt DateTime?
  status                  UserStatus     @default(PENDING_PROVISIONING)
  role                    UserRole       @default(USER)
  name                    String
  passwordHash            String
  personalMailboxId       String?        @unique
  personalMailbox         Mailbox?       @relation("UserPersonalMailbox", fields: [personalMailboxId], references: [id], onDelete: SetNull)
  ownedOrganizations      Organization[] @relation("OrganizationOwner")
  mailboxes               Mailbox[]      @relation("MailboxUser")
  createdAt               DateTime       @default(now())
  updatedAt               DateTime       @updatedAt
}

model Organization {
  id                   String           @id @default(cuid())
  name                 String
  slug                 String           @unique
  ownerId              String
  owner                User             @relation("OrganizationOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  mailPortalEnabled    Boolean          @default(true)
  portalDisplayName    String?
  portalLogoUrl        String?
  portalWelcomeMessage String?
  portalStatus         PortalStatus     @default(ACTIVE)
  domains              Domain[]
  mailboxes            Mailbox[]
  webmailSessions      WebmailSession[]
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt
}

model Domain {
  id                      String       @id @default(cuid())
  name                    String       @unique
  verificationToken       String       @unique
  status                  DomainStatus @default(PENDING)
  verifiedAt              DateTime?
  lastCheckedAt           DateTime?
  verificationError       String?
  dkimSelector            String       @default("mail")
  dkimPublicKey           String?
  dkimPrivateKeyEncrypted String?
  organizationId          String
  organization            Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  mailboxes               Mailbox[]
  createdAt               DateTime     @default(now())
  updatedAt               DateTime     @updatedAt
}

model Mailbox {
  id                 String           @id @default(cuid())
  address            String           @unique
  displayName        String
  type               MailboxType      @default(BUSINESS)
  status             MailboxStatus    @default(PENDING)
  provisioningError  String?
  quotaMb            Int              @default(5120)
  organizationId     String?
  domainId           String?
  userId             String?
  personalUser       User?            @relation("UserPersonalMailbox")
  organization       Organization?    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  domain             Domain?          @relation(fields: [domainId], references: [id], onDelete: Cascade)
  user               User?            @relation("MailboxUser", fields: [userId], references: [id], onDelete: SetNull)
  webmailSessions    WebmailSession[]
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
}

model WebmailSession {
  id                  String       @id @default(cuid())
  mailboxId           String
  organizationId      String
  portalSlug          String
  tokenHash           String       @unique
  encryptedCredential String
  expiresAt           DateTime
  lastActivityAt      DateTime
  revokedAt           DateTime?
  mailbox             Mailbox      @relation(fields: [mailboxId], references: [id], onDelete: Cascade)
  organization        Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt

  @@index([mailboxId])
  @@index([organizationId])
  @@index([portalSlug])
}

enum UserStatus {
  PENDING_PROVISIONING
  PENDING_VERIFICATION
  ACTIVE
  SUSPENDED
  FAILED
}

enum UserRole {
  USER
  WORKSPACE_OWNER
  WORKSPACE_ADMIN
  PLATFORM_ADMIN
  SUPPORT_AGENT
}

enum PortalStatus {
  ACTIVE
  DISABLED
}

enum DomainStatus {
  PENDING
  VERIFYING
  VERIFIED
  ACTIVE
  FAILED
}

enum MailboxStatus {
  PENDING
  PROVISIONING
  ACTIVE
  FAILED
  SUSPENDED
}

enum MailboxType {
  PERSONAL
  BUSINESS
}
